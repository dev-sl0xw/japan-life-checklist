{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Japan Life Checklist Items",
  "description": "items.json 스키마 정의 — CONTRIBUTING.md 참조",
  "type": "object",
  "required": ["schema_version", "data_version", "profile_flags", "categories"],
  "properties": {
    "schema_version":          { "type": "integer", "minimum": 1 },
    "app_min_schema_version":  { "type": "integer", "minimum": 1 },
    "data_version":            { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "content_review_cadence":  { "type": "string" },
    "profile_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label_ko"],
        "properties": {
          "id":       { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "label_ko": { "type": "string" },
          "label_ja": { "type": "string" }
        }
      }
    },
    "categories": {
      "type": "array",
      "items": { "$ref": "#/definitions/category" }
    }
  },
  "definitions": {
    "visible_when": {
      "type": "object",
      "properties": {
        "any_of":  { "type": "array", "items": { "type": "string" } },
        "none_of": { "type": "array", "items": { "type": "string" } }
      }
    },
    "category": {
      "type": "object",
      "required": ["id", "label_ko", "subcategories"],
      "properties": {
        "id":            { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "icon":          { "type": "string" },
        "label_ko":      { "type": "string" },
        "label_ja":      { "type": "string" },
        "visible_when":  { "$ref": "#/definitions/visible_when" },
        "subcategories": { "type": "array", "items": { "$ref": "#/definitions/subcategory" } }
      }
    },
    "subcategory": {
      "type": "object",
      "required": ["id", "label_ko", "items"],
      "properties": {
        "id":           { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "label_ko":     { "type": "string" },
        "label_ja":     { "type": "string" },
        "visible_when": { "$ref": "#/definitions/visible_when" },
        "items":        { "type": "array", "items": { "$ref": "#/definitions/item" } }
      }
    },
    "item": {
      "type": "object",
      "required": ["id", "title_ko", "risk_level", "last_verified"],
      "properties": {
        "id":                   { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "title_ko":             { "type": "string" },
        "title_ja":             { "type": "string" },
        "description_ko":       { "type": "string" },
        "description_ja":       { "type": "string" },
        "timeline":             { "type": ["string", "null"] },
        "timeline_offset_days": { "type": ["integer", "null"] },
        "tags":                 { "type": "array", "items": { "type": "string" } },
        "risk_level":           { "type": "string", "enum": ["legal_deadline", "money_loss", "service_interruption", "convenience"] },
        "visible_when":         { "$ref": "#/definitions/visible_when" },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label_ko", "url", "publisher", "last_verified"],
            "properties": {
              "label_ko":      { "type": "string" },
              "url":           { "type": "string", "pattern": "^https://" },
              "publisher":     { "type": "string" },
              "last_verified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
            }
          }
        },
        "last_verified":      { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "needs_verification": { "type": "boolean" },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label_ko", "url"],
            "properties": {
              "label_ko": { "type": "string" },
              "url":      { "type": "string", "pattern": "^https://" }
            }
          }
        }
      }
    }
  }
}
